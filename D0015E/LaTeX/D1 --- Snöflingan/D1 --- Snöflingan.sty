\section{A Famous Fractal: The Koch Snowflake}
% \textit makes things Italics
%\cite is a citation
The \emph{Koch snowflake}, one of the first fractals, is based on work by the Swedish mathematician Helge von Koch \cite{koch}. It is what we get if we start with an equilateral triangle
% inserts an image
% h! makes it so the image is in the same place we are typing and not at the top or at the bottom, and for the compiler to force the impication on latex
\begin{figure}[h!]
\centering
\includegraphics[width=10cm]{snowflake.jpg}
\caption{The Koch snowflake after 0, 1, 2, and 3 iterations.}
\end{figure}

\noindent and repeat the following an infinite number of times:
% makes an indent for a block
\begin{quote}
    \textit{First, divide all line segments into three segments of equal length. Then draw, for each middle line segment, an equilateral triangle that has the middle segment as its base and points outward. Finally, remove all middle segments.}
\end{quote}
\noindent Figure 1 shows the first iterations in the construction.
\section{Two properties}
% creates a theorem with automatic numbering
\newtheorem{theorem}{Theorem}
% The text thats going to go after the theorem
\begin{theorem}
The Koch snowflake has infinite length.
\end{theorem}
% starts a proof section and ends with a square
\begin{proof}
% $ $ makes a variable or a mathematic symbol
Let $\Delta$ denote a triangle, with side length $s$, on which we base the construction of a snowflake. Let $N_{i}$ denote the number of line segments, and $L_{i}$ the length of the segments, in iteration $i$ of the construction. Then,
% \[ \] centersa the math equation
%  Cases ads the { and alligns everythinhg
\[
N_{n} =
\begin{cases}
3, & \text{if } n=0 \text{ (that is, before any iterations), and} \\
4 N_{n-1}, & \text{otherwise}
\end{cases}
\]
\noindent This solves to
% equation centers and adds  a number at the far right
\begin{equation} 
N_{n} = 3 \cdot 4^{n},
\end{equation}
\noindent while
\begin{equation}
L_{n} = \frac{L_{n-1}}{3} = \frac{L_{n-2}}{3^{2}} = \frac{L_{n-3}}{3^{3}} = \frac{L_{n-4}}{3^{4}} = \ldots = \frac{L_{0}}{3^{n}} = \frac{s}{3^{n}}.
\end{equation}
\noindent From Eqs. 1 and 2, the total length
\[
N_{n} L_{n} = 3 \cdot 4^{n} \frac{s}{3^{n}} = 3 s \frac{4^{n}}{3^{n}} = 3 s \left( \frac{4}{3} \right)^{n}.
\]
\noindent Since ${4}/{3} > 1$, it follows that $N_{n} L_{n}$ tends to infinity as $n \rightarrow \infty$, which means the Koch snowflake indeed has infinite length.
\end{proof}
\newpage
\begin{theorem}
The Koch snowflake has finite area.
\end{theorem}
\begin{proof}
\noindent In an iteration, a triangle is added on each line segment of the previous iteration. Therefore, in iteration $n$, the number of new triangles $T_{n} = N_{n-1}$, which, by Eq. 1, can be simplified to
\begin{equation}
T_{n} = \frac{3}{4} \cdot 4^{n}.
\end{equation}
\noindent The area $a_{n}$ of each such triangle, with the exception of the area
\[
a_{0} = \frac{\sqrt{3}}{4} s^{2}
\]
\noindent of $\Delta$, the initial equilateral triangle, is one ninth of the area of a triangle added in iteration $n-1$, or
\begin{equation}
a_{n} = \frac{a_{n-1}}{9} = \frac{a_{n-2}}{9^{2}} = \ldots = \frac{a_{1}}{9^{n-1}} = \frac{a_{0}}{9^{n}}.
\end{equation}
\noindent This means that in iteration $n$, by Eqs. 3 and 4, the area of all added triangles
\[
b_{n} = T_{n} a_{n} = \left( \frac{3}{4} \cdot 4^{n} \right) \left( \frac{a_{0}}{9^{n}} \right) = \frac{3 a_{0}}{4} \left( \frac{4}{9} \right)^{n}.
\]
\noindent All in all, after iteration $n$, the total area
\[
% aligned aligns all the equal signs on top of eachother, by the helkp of &
\begin{aligned}
A_{n} & = a_{0} + \sum_{k=1}^{n} b_{k} \\
& = a_{0} \left( 1 + \frac{3}{4} \sum_{k=1}^{n} \left( \frac{4}{9} \right)^{k} \right) \\
& = a_{0} \left( 1 + \frac{1}{3} \sum_{k=0}^{n-1} \left( \frac{4}{9} \right)^{k} \right) \\
& = a_{0} \left( 1 + \frac{3}{5} \left( 1 - \left( \frac{4}{9} \right)^{n} \right) \right) \\
& = \frac{a_{0}}{5} \left( 8 - 3 \left( \frac{4}{9} \right)^{n} \right).
\end{aligned}
\]
\noindent Now, since the denominator is larger than the numerator,
\[
\lim_{n \rightarrow \infty} 3 \left( \frac{4}{9} \right)^{n} = 0,
\]
\noindent and it follows that $\lim_{n \rightarrow \infty} A_{n} = {8 a_{0}}/{5}$.
This shows that the Koch snowflake indeed has finite area.
\end{proof}
